---
import BaseLayout from '../../layouts/BaseLayout.astro';
const weeklyModules = import.meta.glob('/src/pages/weekly/*.{md,mdx}', { eager: true });
const weeklyPosts = Object.values(weeklyModules)
  .filter(m => m.url && m.url !== '/weekly/')
  .sort((a, b) => new Date(b.frontmatter.pubDate) - new Date(a.frontmatter.pubDate));
---

<BaseLayout title="AI 周刊 · Kehao Chen">
  <div class="container page">
    <h1>AI 周刊</h1>
    <div class="post-list">
      {weeklyPosts.map(post => (
        <a href={post.url} class="post-item">
          <span class="title">{post.frontmatter.title}</span>
          <span class="date">{post.frontmatter.pubDate}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
