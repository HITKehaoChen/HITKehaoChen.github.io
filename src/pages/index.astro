---
import BaseLayout from '../layouts/BaseLayout.astro';
const weeklyModules = import.meta.glob('/src/pages/weekly/*.{md,mdx}', { eager: true });
const weeklyPosts = Object.values(weeklyModules)
  .filter(m => m.url && m.url !== '/weekly/')
  .sort((a, b) => new Date(b.frontmatter.pubDate) - new Date(a.frontmatter.pubDate));
const blogModules = import.meta.glob('/src/pages/posts/*.{md,mdx}', { eager: true });
const blogPosts = Object.values(blogModules)
  .filter(m => m.url && m.url !== '/posts/')
  .sort((a, b) => new Date(b.frontmatter.pubDate) - new Date(a.frontmatter.pubDate));
---

<BaseLayout title="Kehao Chen · AI & Reflections">
  <div class="container">
    <section class="hero">
      <h1>AI 观察 · 经验 · 思考</h1>
      <p class="subtitle">记录 AI 行业的技术演进与个人实践中的思考沉淀。</p>
    </section>

    <section style="margin-bottom: 56px;">
      <h2 style="font-size:22px;font-weight:600;margin-bottom:24px;padding-bottom:8px;border-bottom:2px solid var(--fg);display:inline-block;">最新周刊</h2>
      <div class="post-list">
        {weeklyPosts.slice(0, 5).map(post => (
          <a href={post.url} class="post-item">
            <span class="title">{post.frontmatter.title}</span>
            <span class="date">{post.frontmatter.pubDate}</span>
          </a>
        ))}
      </div>
      <a href="/weekly/" class="view-all">查看全部 →</a>
    </section>

    <section style="margin-bottom: 56px;">
      <h2 style="font-size:22px;font-weight:600;margin-bottom:24px;padding-bottom:8px;border-bottom:2px solid var(--fg);display:inline-block;">最新文章</h2>
      <div class="post-list">
        {blogPosts.slice(0, 5).map(post => (
          <a href={post.url} class="post-item">
            <span class="title">{post.frontmatter.title}</span>
            <span class="date">{post.frontmatter.pubDate}</span>
          </a>
        ))}
      </div>
      <a href="/posts/" class="view-all">查看全部 →</a>
    </section>
  </div>
</BaseLayout>

<style>
  .hero { padding: 80px 0 64px; text-align: center; }
  .hero h1 { font-size: 36px; font-weight: 600; line-height: 1.3; letter-spacing: -0.5px; margin-bottom: 12px; }
  .subtitle { font-size: 17px; color: var(--muted); }
  @media (max-width: 600px) { .hero h1 { font-size: 28px; } .hero { padding: 56px 0 40px; } }
</style>
